<html>

<head>
  <meta charset="utf-8">
  <script src="https://aframe.io/releases/1.6.0/aframe.min.js"></script>

  <style>
    html, body {
      margin: 0;
      overflow: hidden;
      background-color: transparent !important;
      background: transparent !important;
    }
    .a-canvas {
      background-color: transparent !important;
      background: transparent !important;
    }
    .error-message {
      position: fixed;
      top: 20px;
      left: 20px;
      right: 20px;
      padding: 12px;
      background: rgba(200, 0, 0, 0.85);
      color: white;
      font-family: sans-serif;
      border-radius: 8px;
      z-index: 9999;
    }
    /* Debug-Overlay, zeigt euch live den XR-Status an.
       Kann nach dem Testen einfach entfernt werden. */
    #xr-debug {
      position: fixed;
      bottom: 10px;
      left: 10px;
      padding: 8px 12px;
      background: rgba(0,0,0,0.6);
      color: #0f0;
      font-family: monospace;
      font-size: 12px;
      border-radius: 6px;
      z-index: 9999;
      max-width: 90vw;
      white-space: pre-wrap;
    }
  </style>
</head>

<body>
  <div id="xr-debug">XR-Status: warte auf Session...</div>

  <a-scene
    webxr="mode: ar; requiredFeatures: local-floor; optionalFeatures: hit-test;"
    vr-mode-ui="enterVR: false; enterAR: true"
    renderer="alpha: true; colorManagement: true; clearColor: #000000; clearAlpha: 0; foveationLevel: 0;"
    background="transparent: true">

    <a-entity light="type: ambient; color: #BBB"></a-entity>
    <a-entity light="type: directional; color: #FFF; intensity: 0.6" position="-0.5 1 1"></a-entity>

    <a-entity id="ar-viewer" position="0 0 -1"></a-entity>
  </a-scene>

  <script>
    // Das Model-URL aus der Adresszeile auslesen (alles, was nach dem "?" steht)
    const modelUrl = window.location.search.substring(1);
    const viewer = document.getElementById('ar-viewer');
    const debugEl = document.getElementById('xr-debug');

    if (modelUrl && modelUrl.trim() !== "") {
      viewer.setAttribute('gltf-model', modelUrl);
    } else {
      viewer.style.display = "none";
      const errorDiv = document.createElement('div');
      errorDiv.className = "error-message";
      errorDiv.innerText = "Fehler: Kein 3D-Modell in der URL angegeben!";
      document.body.appendChild(errorDiv);
    }

    const sceneEl = document.querySelector('a-scene');

    sceneEl.addEventListener('enter-vr', function () {
      const isAR = this.is('ar-mode');
      let blendMode = 'unbekannt';

      // xrSession liegt je nach A-Frame-Version an unterschiedlichen Stellen,
      // daher beide Varianten abfragen
      const xrSession = this.xrSession || (this.renderer && this.renderer.xr && this.renderer.xr.getSession && this.renderer.xr.getSession());

      if (xrSession) {
        blendMode = xrSession.environmentBlendMode || 'nicht vorhanden';
      }

      const msg = `XR-Modus: ${isAR ? 'AR' : 'VR'}\nenvironmentBlendMode: ${blendMode}`;
      console.log(msg);
      debugEl.innerText = msg;

      if (isAR) {
        // Bei korrektem AR-Modus übernimmt eigentlich der WebXR-Compositor
        // die Transparenz. Dieser Block ist nur ein zusätzliches Sicherheitsnetz
        // und sollte normalerweise nichts mehr bewirken müssen.
        const renderer = this.renderer;
        if (renderer) {
          renderer.setClearColor(0x000000, 0);
          renderer.clear();
        }
      }

      if (blendMode === 'opaque') {
        debugEl.style.color = '#f55';
        debugEl.innerText += '\n⚠️ Session ist opak -> kein echter Passthrough!';
      }
    });

    sceneEl.addEventListener('exit-vr', function () {
      debugEl.innerText = 'XR-Status: Session beendet';
    });
  </script>
</body>

</html>
